-- 9. View booking details using join
select b.booking_id,
       g.name            as guest_name,
       g.phone,
       r.room_number,
       r.room_type,
       r.price_per_day,
       b.check_in_date,
       b.check_out_date,
       (julianday(b.check_out_date) - julianday(b.check_in_date)) as nights_stayed
from bookings b
join guests g on b.guest_id = g.guest_id
join rooms  r on b.room_id  = r.room_id;

-- 10. Update room status (mark room 301 as Booked)
