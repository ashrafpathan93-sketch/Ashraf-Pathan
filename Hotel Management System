-- 1. Drop tables if they exist
drop table if exists payments;
drop table if exists bookings;
drop table if exists rooms;
drop table if exists guests;

-- 2. Create tables

create table guests (
    guest_id  integer primary key autoincrement,
    name      text    not null,
    phone     text    not null,
    email     text    unique not null
);

create table rooms (
    room_id       integer primary key autoincrement,
    room_number   text    unique not null,
    room_type     text    not null check(room_type in ('Single','Double','Deluxe','Suite','Penthouse')),
    price_per_day real    not null check(price_per_day > 0),
    status        text    not null check(status in ('Available','Booked')) default 'Available'
);

create table bookings (
    booking_id     integer primary key autoincrement,
    guest_id       integer not null,
    room_id        integer not null,
    check_in_date  text    default current_date,
    check_out_date text,
    foreign key (guest_id) references guests(guest_id),
    foreign key (room_id)  references rooms(room_id)
);

create table payments (
    payment_id   integer primary key autoincrement,
    booking_id   integer not null,
    amount       real    not null check(amount > 0),
    payment_date text    default current_date,
    foreign key (booking_id) references bookings(booking_id)
);

