set status = 'Booked'
where room_number = '301';

select room_number, room_type, status from rooms where room_number = '301';

-- 11. Calculate total revenue
select sum(amount) as total_revenue from payments;

-- 12. Find guest booking history (guest_id = 1)
select b.booking_id,
       g.name           as guest_name,
       r.room_number,
       r.room_type,
       b.check_in_date,
       b.check_out_date,
       p.amount         as amount_paid,
       p.payment_date
from bookings b
join guests   g on b.guest_id   = g.guest_id
join rooms    r on b.room_id    = r.room_id
join payments p on b.booking_id = p.booking_id
where g.guest_id = 1;

-- 13. Delete booking / checkout (booking_id = 1)
delete from payments where booking_id = 1;
delete from bookings where booking_id = 1;
update rooms set status = 'Available' where room_id = 1;

-- 14. Display all bookings
select b.booking_id,
       g.name       as guest_name,
       r.room_number,
       r.room_type,
       b.check_in_date,
       b.check_out_date,
       r.status     as room_status
from bookings b
join guests g on b.guest_id = g.guest_id
join rooms  r on b.room_id  = r.room_id
order by b.booking_id;
